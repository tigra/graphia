#!/usr/bin/env bash
set -euo pipefail

# Graphia IaC wrapper — runs terraform inside a container so every developer
# (and CI) executes against the same pinned Terraform + provider versions
# regardless of what's installed on the host. See the
# `project_terraform_container` memory for the rationale.
#
# Container runtime is auto-detected: Podman and Docker are both first-class
# supported. Whichever the developer has installed is used. Set
# TERRAFORM_IMAGE to override the pinned image tag.

# Validate that an AWS profile is selected — the AWS provider inside the
# container relies on the standard credential chain resolving via AWS_PROFILE.
# Without this guard the user sees Terraform's generic "No valid credential
# sources" message and has to figure out the cause themselves.
if [ -z "${AWS_PROFILE:-}" ]; then
  cat <<EOF >&2
ERROR: AWS_PROFILE is not set.

Configure it once:
  - Add AWS_PROFILE=<your-profile> to .env at the repo root, OR
  - Export it in your shell: export AWS_PROFILE=<your-profile>

Then refresh credentials before invoking terraform:
  aws sso login --profile <your-profile>
EOF
  exit 1
fi

# Detect container runtime: prefer podman, fall back to docker.
# Both runtimes are explicitly supported (per project_terraform_container memory);
# whichever the developer has installed is fine.
runtime=""
if command -v podman >/dev/null 2>&1; then
  runtime=podman
elif command -v docker >/dev/null 2>&1; then
  runtime=docker
else
  cat <<EOF >&2
ERROR: No container runtime found. Graphia's IaC layer requires Podman or Docker.

Install one and try again:
  - Podman:  https://podman.io/docs/installation
  - Docker:  https://docs.docker.com/engine/install/
EOF
  exit 1
fi

# Pinned image; override with TERRAFORM_IMAGE env var if needed.
image="${TERRAFORM_IMAGE:-docker.io/hashicorp/terraform:1.13.1}"

# Mount the repo root (not just `infra/terraform/`) so resources can reference
# sibling-directory artifacts via `path.module`-relative paths — most notably
# `aws_lambda_function.filename` pointing at `../lambda/.build/*.zip` (ADR
# 005). Computing the repo root from `tf`'s own location keeps the wrapper
# usable whether you invoke it as `./tf …` or via `make tf-…`.
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"
rel_dir="${script_dir#$repo_root/}"

# Mount the repo root + AWS config (read-only) and forward the relevant env
# vars so the standard credential chain resolves the developer's SSO profile.
exec "$runtime" run --rm -it \
  -v "$repo_root:/workspace" -w "/workspace/$rel_dir" \
  -v "$HOME/.aws:/root/.aws:ro" \
  -e AWS_PROFILE -e AWS_REGION -e AWS_DEFAULT_REGION \
  "$image" "$@"
