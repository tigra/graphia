#!/usr/bin/env bash
set -euo pipefail

# Graphia IaC wrapper — runs terraform inside a container so every developer
# (and CI) executes against the same pinned Terraform + provider versions
# regardless of what's installed on the host. See the
# `project_terraform_container` memory for the rationale.
#
# Container runtime is auto-detected: Podman and Docker are both first-class
# supported. Whichever the developer has installed is used. Set
# TERRAFORM_IMAGE to override the pinned image tag.

# Detect container runtime: prefer podman, fall back to docker.
# Both runtimes are explicitly supported (per project_terraform_container memory);
# whichever the developer has installed is fine.
runtime=""
if command -v podman >/dev/null 2>&1; then
  runtime=podman
elif command -v docker >/dev/null 2>&1; then
  runtime=docker
else
  cat <<EOF >&2
ERROR: No container runtime found. Graphia's IaC layer requires Podman or Docker.

Install one and try again:
  - Podman:  https://podman.io/docs/installation
  - Docker:  https://docs.docker.com/engine/install/
EOF
  exit 1
fi

# Pinned image; override with TERRAFORM_IMAGE env var if needed.
image="${TERRAFORM_IMAGE:-docker.io/hashicorp/terraform:1.13.1}"

# Mount the workspace + AWS config (read-only) and forward the relevant env vars
# so the standard credential chain resolves the developer's SSO profile.
exec "$runtime" run --rm -it \
  -v "$(pwd):/workspace" -w /workspace \
  -v "$HOME/.aws:/root/.aws:ro" \
  -e AWS_PROFILE -e AWS_REGION -e AWS_DEFAULT_REGION \
  "$image" "$@"
