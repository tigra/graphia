# Environment & secrets
.env
.env.*
!.env.example
*.env

# Local verification / scratch artifacts (may contain account ids, ARNs, profiles)
obs_log.txt

# Local-only notes (internal account/profile details — never committed)
*.local.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# Tooling caches
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Graphia runtime artifacts (checkpoints + JSONL trace log)
.graphia/

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Claude Code per-user overrides (settings.json is shared; .local.json is per-user)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Terraform — local working state (provider plugins, state, var files).
# The lockfile (.terraform.lock.hcl) IS committed; everything else is not.
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
*.tfvars.json
!terraform.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
